{
    "name": "aliziodev/laravel-wilayah-logos",
    "description": "Addon asset logo/lambang daerah Indonesia (Provinsi dan Kab/Kota) untuk package aliziodev/laravel-wilayah.",
    "keywords": [
        "laravel",
        "indonesia",
        "wilayah",
        "logo",
        "lambang",
        "daerah",
        "asset"
    ],
    "homepage": "https://github.com/aliziodev/laravel-wilayah-logos",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Aliziodev",
            "email": "aliziodev@gmail.com"
        }
    ],
    "require": {
        "ext-zip": "*",
        "php": "^8.2|^8.3",
        "aliziodev/laravel-wilayah": "^1.0",
        "illuminate/support": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.7|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0",
        "pestphp/pest-plugin-drift": "^3.0|^4.0",
        "laravel/pint": "^1.27"
    },
    "autoload": {
        "psr-4": {
            "Aliziodev\\WilayahLogos\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Aliziodev\\WilayahLogos\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Aliziodev\\WilayahLogos\\LogosServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "version": "1.0.2"
}
